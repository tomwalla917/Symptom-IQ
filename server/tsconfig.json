{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    /* Modules */
    "rootDir": "src",

    /* Emit */
    "outDir": "dist",
    "noEmit": false,          // override parent — we DO want output files
    
    /* Fix module settings for Node.js */
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src"],
  "typeRoots": ["./node_modules/@types", "./src/types"]
}